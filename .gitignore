# Root-level ignores for the whole repository.
# (The Next.js app also has its own frontend/.gitignore.)

# Dependencies
node_modules/

# Next.js build output
.next/
out/
build/

# Environment & secrets
.env
.env*.local
*.pem

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

# TypeScript
*.tsbuildinfo
